daemon/target/
*.log
/etc/foxram/
.idea
.codex
.claude

# Generated by build.rs from /sys/kernel/btf/vmlinux at compile time —
# checking it in would freeze us to one specific kernel and balloon
# the diff (~3 MB / 160k LOC).
daemon/src/bpf/vmlinux.h

# Per-host benchmark output. Re-run scripts under bench/scripts/ to
# regenerate; the .gitkeep marker preserves the directory. Plots ARE
# checked in so the README's <picture> tags resolve on GitHub without
# anyone needing to clone + run analyze.R first.
bench/results/*
!bench/results/.gitkeep
!bench/results/plots/
!bench/results/plots/*.png
